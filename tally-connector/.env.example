# Copy to .env and fill in.

# Your deployed Kanrad URL (no trailing slash)
KANRAD_URL=https://www.kanrad.in

# Must match TALLY_CONNECTOR_SECRET set in Kanrad's environment (Vercel)
TALLY_CONNECTOR_SECRET=replace-with-a-long-random-secret

# Tally Prime XML gateway (Gateway of Tally → F1 → Advanced → enable "Act as Server", port 9000)
TALLY_URL=http://localhost:9000

# Must exactly match the Tally company name
TALLY_COMPANY=KANRAD ERP

# How often to sync, in seconds
POLL_SECONDS=60

# Voucher pull: how many months of history to mirror, and how often
# (every N poll cycles; with POLL_SECONDS=60 the default 30 ≈ every 30 min)
VOUCHER_MONTHS=12
VOUCHER_PULL_EVERY_CYCLES=30
